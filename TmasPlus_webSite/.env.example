# ==================== T+PLUS DASHBOARD — ENV EXAMPLE ====================
# Copy this file to `.env` and fill in the values.
# NEVER commit a real `.env` to git (it is already in .gitignore).
#
# Only variables prefixed with VITE_ are exposed to the browser bundle.
# Everything else MUST be configured as a server-side secret
# (Supabase dashboard > Edge Functions > Secrets) and never placed here.

# ---------- SUPABASE — Primary (T+Plus Dashboard) ----------
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ---------- SUPABASE — Secondary (memberships / complaints) ----------
VITE_SUPABASE_SECONDARY_URL=
VITE_SUPABASE_SECONDARY_ANON_KEY=

# ---------- APP CONFIG ----------
VITE_APP_NAME=T+Plus WEB
VITE_APP_VERSION=1.0
VITE_NODE_ENV=development

# ---------- MAPBOX ----------
# Must be a PUBLIC token (pk.*), NEVER a secret token (sk.*).
# Generate at https://account.mapbox.com -> Tokens -> Create a token (public).
VITE_MAPBOX_ACCESS_TOKEN=

# ---------- STORAGE BUCKETS (optional overrides) ----------
# VITE_STORAGE_BUCKET_PROFILES=user-profiles
# VITE_STORAGE_BUCKET_DOCUMENTS=user-documents
# VITE_STORAGE_BUCKET_CARS=car-images
# VITE_STORAGE_BUCKET_BOOKINGS=booking-media

# ==========================================================================
# DO NOT put the following in this file — they are server-side secrets:
#   - RESEND_API_KEY              -> Supabase Edge Function secret
#   - RNMAPBOX_MAPS_DOWNLOAD_TOKEN (sk.*) -> belongs to the mobile app, not web
#   - SUPABASE_SERVICE_ROLE_KEY   -> Supabase Edge Function secret
# ==========================================================================